# =============================================================
# P2P Chat — Environment Variables Reference
# =============================================================
# Copy this file to .env (never commit .env) and fill in real values.
# For Cloud Run, set these in the Variables & Secrets tab when deploying.

# ----------------------------
# Cloudflare TURN (required for WebRTC NAT traversal / relay)
# Get from: Cloudflare Dashboard → Realtime → TURN → your key
# ----------------------------
CF_TURN_KEY_ID=your_cloudflare_turn_key_id_here
CF_TURN_API_TOKEN=your_cloudflare_turn_api_token_here

# ----------------------------
# CORS (production only — comma-separated origins)
# Default in dev: * (all origins)
# ----------------------------
ALLOWED_ORIGINS=https://chat-p2p-x.web.app

# ----------------------------
# Server port (set automatically by Cloud Run)
# ----------------------------
PORT=8080

# ----------------------------
# Spring profile (set to "prod" on Cloud Run)
# ----------------------------
SPRING_PROFILES_ACTIVE=prod
